# Renova — production template (НЕ коммитить реальные секреты)

ENVIRONMENT=production

DATABASE_URL=postgresql+asyncpg://renova:CHANGE_ME@db:5432/renova
PUBLIC_BASE_URL=https://api.renova.app
SECRET_KEY=

# Только https PUBLIC_BASE_URL; иначе startup fail
# alembic upgrade head

ALLOW_CREATE_ALL=false
ALLOW_DEMO_SEED=false

SENTRY_DSN=

# P3-W38 ops / optional AI digest
OPS_ALERT_EMAIL=
OLLAMA_DIGEST_ENABLED=false
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen3

# SMTP (ops alerts / budget). Empty = log-only stub.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
