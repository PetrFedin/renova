# Renova — staging template (НЕ коммитить реальные секреты)
# Скопируйте в .env на сервере / в секреты CI.
# Политика: docs/ENVIRONMENT-PROFILES.md

ENVIRONMENT=staging

# Postgres обязателен (SQLite → startup fail)
DATABASE_URL=postgresql+asyncpg://renova:CHANGE_ME@db:5432/renova

# Не localhost
PUBLIC_BASE_URL=https://api-staging.example.com

# Сгенерировать: openssl rand -hex 32
# Guards отвергнут: change-me, secret, <16 символов, dev-secret-change-me
SECRET_KEY=

# Миграции перед стартом API (create_all запрещён)
# alembic upgrade head

ALLOW_CREATE_ALL=false
ALLOW_DEMO_SEED=false

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=renova-staging

# Staging checklist: без этих ключей checkout → 503 (demo выключен)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
YOOKASSA_WEBHOOK_SECRET=
# Webhook URL: {PUBLIC_BASE_URL}/api/v1/subscription/webhook

SENTRY_DSN=

# OCR: sync|async (async → worker tick/loop)
DOCUMENT_OCR_MODE=async
DOCUMENT_OCR_WORKER_INTERVAL_SEC=5

# E-sign external (Wave 3f). Default off → API 501 для kontur/goskey.
# KONTUR_MODE=off|sandbox|live
# KONTUR_API_KEY=
# KONTUR_API_URL=https://api.kontur.ru/sign/v1
# GOSKEY_MODE=off|sandbox|live
# GOSKEY_CLIENT_ID=
# ESIGN_WEBHOOK_SECRET=

# P3-W11: PUBLIC_BASE_URL — для webhook URL в GET /api/v1/esign/health
# PUBLIC_BASE_URL=https://api.staging.renova.example
# ESIGN_WEBHOOK_SECRET=  # заголовок X-Esign-Secret на POST .../esign/webhooks/kontur

# P3-W38 ops / optional AI digest
OPS_ALERT_EMAIL=
OLLAMA_DIGEST_ENABLED=false
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen3

# SMTP (ops alerts / budget). Empty = log-only stub.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
