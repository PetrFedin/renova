# Renova — staging template (НЕ коммитить реальные секреты)
# Скопируйте в .env на сервере / в секреты CI.
# Политика: docs/ENVIRONMENT-PROFILES.md

ENVIRONMENT=staging

# Postgres обязателен (SQLite → startup fail)
DATABASE_URL=postgresql+asyncpg://renova:CHANGE_ME@db:5432/renova

# Не localhost
PUBLIC_BASE_URL=https://api-staging.example.com

# Сгенерировать: openssl rand -hex 32
# Guards отвергнут: change-me, secret, <16 символов, dev-secret-change-me
SECRET_KEY=

# Миграции перед стартом API (create_all запрещён)
# alembic upgrade head

ALLOW_CREATE_ALL=false
ALLOW_DEMO_SEED=false

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=renova-staging

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
YOOKASSA_WEBHOOK_SECRET=

SENTRY_DSN=
