# === Profile ===
# development | test | staging | production
ENVIRONMENT=development

# --- development (SQLite OK) ---
DATABASE_URL=sqlite+aiosqlite:///./renova.db
PUBLIC_BASE_URL=http://127.0.0.1:8100
SECRET_KEY=dev-secret-change-me

# --- staging / production (Postgres required, no demo seed, no create_all) ---
# ENVIRONMENT=staging
# DATABASE_URL=postgresql+asyncpg://renova:renova@localhost:5433/renova
# PUBLIC_BASE_URL=https://api-staging.renova.app
# SECRET_KEY=replace-with-openssl-rand-hex-32
# Перед стартом: alembic upgrade head

# Optional overrides (default = profile policy)
# ALLOW_CREATE_ALL=true
# ALLOW_DEMO_SEED=true

FNS_NPD_STATUS_URL=https://statusnpd.nalog.ru/api/v1/tracker/taxpayer_status
MOY_NALOG_ENABLED=false

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=renova

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
YOOKASSA_WEBHOOK_SECRET=

SENTRY_DSN=
