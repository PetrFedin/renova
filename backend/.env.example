# === Profile ===
# development | test | staging | production
ENVIRONMENT=development

# --- development (SQLite OK) ---
DATABASE_URL=sqlite+aiosqlite:///./renova.db
PUBLIC_BASE_URL=http://127.0.0.1:8100
SECRET_KEY=dev-secret-change-me
# JWT access token TTL (minutes). Default: 14 days.
# ACCESS_TOKEN_EXPIRE_MINUTES=20160
# Legacy X-User-Id: None=по ENVIRONMENT policy (dev/test=on, staging/production=off).
# Staging/production MUST keep this unset/false — only Authorization: Bearer.
# AUTH_ALLOW_HEADER_USER_ID=false

# --- staging / production (Postgres required, no demo seed, no create_all) ---
# ENVIRONMENT=staging
# DATABASE_URL=postgresql+asyncpg://renova:renova@localhost:5433/renova
# PUBLIC_BASE_URL=https://api-staging.renova.app
# SECRET_KEY=replace-with-openssl-rand-hex-32
# Перед стартом: alembic upgrade head

# Optional overrides (default = profile policy)
# ALLOW_CREATE_ALL=true
# ALLOW_DEMO_SEED=true

FNS_NPD_STATUS_URL=https://statusnpd.nalog.ru/api/v1/tracker/taxpayer_status
MOY_NALOG_ENABLED=false

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=renova

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
YOOKASSA_WEBHOOK_SECRET=

SENTRY_DSN=
# Production: required unless explicit ops exception:
# SENTRY_APPROVED_WITHOUT_DSN=true

# E-sign external (Wave 3f). Default off → API 501 для kontur/goskey.
# KONTUR_MODE=off|sandbox|live
# KONTUR_API_KEY=
# KONTUR_API_URL=https://api.kontur.ru/sign/v1
# GOSKEY_MODE=off|sandbox|live
# GOSKEY_CLIENT_ID=
# ESIGN_WEBHOOK_SECRET=

# P3-W38 ops / optional AI digest
OPS_ALERT_EMAIL=
OLLAMA_DIGEST_ENABLED=false
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen3

# SMTP (ops alerts / budget). Empty = log-only stub.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# FNS receipt live verify (proverkacheka Basic auth)
FNS_RECEIPT_LOGIN=
FNS_RECEIPT_PASSWORD=
# MOY_NALOG_ENABLED=true only after real OAuth; staging without it → 501 on link

# Multi-instance WebSocket fanout (optional). Empty = in-process only.
REDIS_URL=

# «Мой налог» OAuth (empty = scaffold only; never fake connected)
MOY_NALOG_ENABLED=false
MOY_NALOG_CLIENT_ID=
MOY_NALOG_CLIENT_SECRET=
MOY_NALOG_REDIRECT_URI=
MOY_NALOG_AUTHORIZE_URL=https://lknpd.nalog.ru/api/v1/auth/login
MOY_NALOG_TOKEN_URL=

# Comma-separated; staging/prod must not use *
CORS_ALLOWED_ORIGINS=
# Wave-10 ops
ALLOW_ACCOUNT_PURGE=false

# --- Provider-specific (required only when capability enabled) ---
# S3_ENDPOINT set → S3_ACCESS_KEY + S3_SECRET_KEY + S3_BUCKET
# MOY_NALOG_ENABLED=true → CLIENT_ID/SECRET/REDIRECT_URI/TOKEN_URL
# KONTUR_MODE=sandbox|live → KONTUR_API_KEY (+ ESIGN_WEBHOOK_SECRET on staging/prod)
# TWILIO_SID set → TWILIO_TOKEN + TWILIO_FROM
# YOOKASSA_SHOP_ID ↔ YOOKASSA_SECRET (both or neither); webhook secret on staging/prod
