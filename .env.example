# Renova root env example (mobile public + shared pointers)
# Backend secrets: backend/.env.example
# Profiles: docs/ENVIRONMENT-PROFILES.md
# Production checklist: docs/PRODUCTION-READINESS-2026-07.md
#
# Categories:
#   required_always / required_in_production / optional / provider-specific
# NEVER put private secrets in EXPO_PUBLIC_*.

ENVIRONMENT=development

# --- Mobile public (inlined at Expo build) ---
EXPO_PUBLIC_API_URL=http://127.0.0.1:8100
EXPO_PUBLIC_DEMO=1
EXPO_PUBLIC_APP_ENV=development
# Production: set DSN via EAS secrets, or temporary approved exception:
# EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_SENTRY_APPROVED_WITHOUT_DSN=true

# Optional public
# EXPO_PUBLIC_WHISPER_URL=

# --- Shared pointers (real secrets live in backend/.env) ---
DATABASE_URL=sqlite+aiosqlite:///./renova.db
PUBLIC_BASE_URL=http://127.0.0.1:8100
SENTRY_DSN=
# Production without Sentry: SENTRY_APPROVED_WITHOUT_DSN=true

S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=renova
S3_SECRET_KEY=renova123
S3_BUCKET=renova

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
YOOKASSA_WEBHOOK_SECRET=

MOY_NALOG_ENABLED=false
MOY_NALOG_CLIENT_ID=
MOY_NALOG_CLIENT_SECRET=
MOY_NALOG_REDIRECT_URI=
MOY_NALOG_TOKEN_URL=

REDIS_URL=
CORS_ALLOWED_ORIGINS=
ALLOW_ACCOUNT_PURGE=false
