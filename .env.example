# Renova root env example (mobile + shared)
# Backend details: backend/.env.example
# Profiles: docs/ENVIRONMENT-PROFILES.md

ENVIRONMENT=development

DATABASE_URL=sqlite+aiosqlite:///./renova.db
# DATABASE_URL=postgresql+asyncpg://renova:renova@localhost:5433/renova
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=renova
S3_SECRET_KEY=renova123
S3_BUCKET=renova
PUBLIC_BASE_URL=http://127.0.0.1:8100
CONTRACTOR_FREE_PROJECT_LIMIT=1

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
YOOKASSA_WEBHOOK_SECRET=

ENVIRONMENT=development
SENTRY_DSN=
EXPO_PUBLIC_SENTRY_DSN=
CLOUDFRONT_DOMAIN=
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_ID=
TWILIO_SID=

# Multi-instance WebSocket fanout (optional). Empty = in-process only.
REDIS_URL=

# «Мой налог» OAuth (empty = scaffold only; never fake connected)
MOY_NALOG_ENABLED=false
MOY_NALOG_CLIENT_ID=
MOY_NALOG_CLIENT_SECRET=
MOY_NALOG_REDIRECT_URI=
MOY_NALOG_AUTHORIZE_URL=https://lknpd.nalog.ru/api/v1/auth/login
MOY_NALOG_TOKEN_URL=
# Dev-only bypass «Включить флаг без OAuth». Игнорируется в staging/production даже если true.
MY_NALOG_DEV_BYPASS_ENABLED=false


# Comma-separated; staging/prod must not use *
CORS_ALLOWED_ORIGINS=
# Wave-10 ops
ALLOW_ACCOUNT_PURGE=false

# OCR Document Center (SoT = GET /api/v1/ocr/health)
# provider: heuristic|local|stub → mode=local; demo → mode=demo; none|off → mode=off
DOCUMENT_OCR_ENABLED=true
DOCUMENT_OCR_PROVIDER=heuristic
DOCUMENT_OCR_MODE=sync
