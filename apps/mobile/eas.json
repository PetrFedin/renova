{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://127.0.0.1:8100",
        "EXPO_PUBLIC_DEMO": "1",
        "EXPO_PUBLIC_APP_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-staging.example.com",
        "EXPO_PUBLIC_DEMO": "0",
        "EXPO_PUBLIC_APP_ENV": "staging"
      }
    },
    "testflight": {
      "extends": "production",
      "distribution": "store",
      "channel": "testflight",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-staging.example.com",
        "EXPO_PUBLIC_DEMO": "0",
        "EXPO_PUBLIC_APP_ENV": "staging"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.renova.example.com",
        "EXPO_PUBLIC_DEMO": "0",
        "SENTRY_ORG": "renova",
        "SENTRY_PROJECT": "mobile",
        "EXPO_PUBLIC_APP_ENV": "production"
      }
    },
    "staging": {
      "extends": "preview",
      "distribution": "internal",
      "channel": "staging",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api-staging.example.com",
        "EXPO_PUBLIC_DEMO": "0",
        "EXPO_PUBLIC_APP_ENV": "staging"
      }
    }
  },
  "submit": {
    "testflight": {
      "ios": {}
    },
    "production": {
      "ios": {},
      "android": {
        "track": "internal"
      }
    }
  }
}
