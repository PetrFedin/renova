# Expo public env (inlined at build time via EAS profile env or local export)
# Не коммитьте реальные staging/production URL с секретами.

# Development (simulator / local API)
EXPO_PUBLIC_API_URL=http://127.0.0.1:8100
EXPO_PUBLIC_DEMO=1

# Staging / TestFlight — задайте в eas.json profile testflight или:
# EXPO_PUBLIC_API_URL=https://api-staging.your-domain.ru
# EXPO_PUBLIC_DEMO=0

# Optional
# EXPO_PUBLIC_WHISPER_URL=

# OCR / Мой налог modes приходят с backend health — не хардкодить DEMO в клиенте.
