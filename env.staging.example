# Renova staging — copy to backend/.env or secrets (do not commit secrets)
# docs/H0-STAGING-RUNBOOK-2026-07-19.md · npm run h0:check

ENVIRONMENT=staging
DATABASE_URL=postgresql+asyncpg://renova:CHANGE_ME@db:5432/renova
SECRET_KEY=replace-with-random-32plus-chars
PUBLIC_BASE_URL=https://api.YOUR-DOMAIN.com

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
YOOKASSA_WEBHOOK_SECRET=

# Mobile / EAS Secrets:
# EXPO_PUBLIC_API_URL=https://api.YOUR-DOMAIN.com
# EXPO_PUBLIC_APP_ENV=staging
# EXPO_PUBLIC_DEMO=0
